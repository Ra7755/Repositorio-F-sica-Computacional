pend_manual = (np.log10(promedio_manual[-1]) - np.log10(promedio_manual[-2])) / \
              (np.log10(N_tiempos[-1]) - np.log10(N_tiempos[-2]))

print("Exponente estimado Manual:", round(pend_manual, 2))
