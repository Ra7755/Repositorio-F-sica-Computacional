# Configuracion de parámetros 

N = 4    
dt = 0.1
tiempos = np.arange(0, 10, dt)
regimenes = {'B/J << 1': (1.0, 0.1), 'B/J = 1': (1.0, 1.0), 'B/J >> 1': (0.1, 1.0)}

# Estado inicial

down = np.array([0, 1])
psi_0 = down
for _ in range(N - 1):
    psi_0 = np.kron(psi_0, down) #(np.kron = producto tensorial)

plt.figure(figsize=(10, 6))

for nombre, (J, B) in regimenes.items():
    H = construccion_hamiltoniano(N, J, B)
    probs = []

    # Evolucion paso a paso
    U_dt = expm(-1j * H * dt)
    psi_t = psi_0.copy()
    
    for t in tiempos:
        #Calculamos probabilidad de retorno
        p_t = np.abs(np.vdot(psi_0, psi_t))**2
        probs.append(p_t)

        # Evoluciona al sigueinte paso

        psi_t = U_dt @ psi_t # @ multiplicador de matrices por vector

    plt.plot(tiempos, probs, label=nombre)

plt.xlabel("Tiempo")
plt.ylabel("Probabilidad de retorno P(t)")
plt.legend()
plt.title("Evolución de la probabilidad de retorno")
plt.show()


