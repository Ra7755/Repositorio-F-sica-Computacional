X= [] #lista para almacenar los X_k

for k in range (N):
    x_k = 0.0 + 0.0j
    for n in range(N):
        x_k += x_n[n]*np.exp((-2j*np.pi*k*n)/N)
    X.append(x_k)

X = np.array(X) # Lo pasamos a un array por comodidad

#-----------------------
# Inciso (c)}
#-----------------------

magnitud = np.abs(X)
frecuencias = np.arange(N) * fs/N

