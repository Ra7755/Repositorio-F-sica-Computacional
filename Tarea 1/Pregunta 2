plt.figure(figsize=(10, 6))
plt.plot(N_tiempos, promedio_manual, 'o-', label='Manual (Promedio)')
plt.plot(N_tiempos, promedio_numpy, 's-', label='NumPy (Promedio)')
plt.xlabel("Tamaño de la señal (N)")
