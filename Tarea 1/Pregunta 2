#-----------------------
# Inciso (e)
#-----------------------

N_tiempos = [10**2, 10**3, 10**4]
repeticiones = 15

# Lista para guardar los promedios de cada N (En (f) se explica mejor)
promedio_manual =[]
promedio_numpy = []


for n_prueba in N_tiempos:

    # listas temporales para las 15 iteraciones

    tiempo_n_manual = []
    tiempo_n_numpy= []

    for i in range(repeticiones):

        #Creamos una señar para un N tiempo específico
        t_prueba = np.arange(n_prueba) * delta_t
        x_prueba = np.sin(2*np.pi*f1* t_prueba) + 0.5*np.sin(2*np.pi*f2* t_prueba)

        # Medimos TDF manual
        inicio_manual = time.time() 
        # Codigo del inciso (b)
        X_resultado= [] #

        for k in range (n_prueba):
            x_k = 0.0 + 0.0j
            for n in range(n_prueba):
                x_k += x_prueba[n]*np.exp((-2j*np.pi*k*n)/n_prueba)
            X_resultado.append(x_k)

        fin_manual = time.time()
        tiempo_n_manual.append(fin_manual - inicio_manual)

        # Medimos TDF numpy

        inicio_numpy = time.time()
        resultado_numpy = np.fft.fft(x_prueba)
        fin_numpy = time.time()
        tiempo_n_numpy.append(fin_numpy - inicio_numpy)

    # Resultados

    #print ("Para N : ", n_prueba)
    #print ("El código manual tarda : ", tiempo_manual, "segundos")
    #print ("Numpy tarda : ", tiempo_numpy, "segundos")

    promedio_manual.append(np.mean(tiempo_n_manual))
    promedio_numpy.append(np.mean(tiempo_n_numpy))


    print("Terminado N =", n_prueba)
    print("Promedio Manual:", promedio_manual[-1], "segundos")

#-----------------------
