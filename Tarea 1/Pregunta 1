# Definimos las matruces de Pauli

sx = np.array([[0,1],
               [1,0]])
sz = np.array([[1,0],
               [0,-1]])
# Matriz identidad
I = np.array([[1,0],
             [0,1]])


# Creamos una funcion para los operadores en j

def sigma_j(op, j, N):
    #Generamos un producto tensorial
    res = 1
    for i in range(1, N+1):
        if i == j :
            res = np.kron(res, op)
        else:
            res = np.kron(res, I)
    return res

# Contruimos el hamiltoniano completo

def construccion_hamiltoniano(N, J, B):
    dim = 2**N #Resultado del inciso A 

    H = np.zeros((dim,dim), dtype=complex)

    # Iteracion J entre espines vecinos
    for i in range(1, N):
        term_x = np.dot(sigma_j(sx, i, N), sigma_j(sx, i+1, N))
        H+= J * term_x

    # Término del campo transversal (B)
    for i in range(1, N+1):
        H+= B* sigma_j(sz, i, N)

    return H

