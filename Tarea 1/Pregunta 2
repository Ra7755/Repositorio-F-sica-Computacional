# Cálculo de la transformada usando el algoritmo de NumPy
X_fft = np.fft.fft(x_n)

# fftfreq(número_de_puntos, espaciado_temporal)
frecuencias_fft = np.fft.fftfreq(N, d=delta_t)

#print("Primeros 5 valores de la FFT de NumPy:")
