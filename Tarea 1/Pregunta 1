    for _ in range(iteraciones):
        t_inicio = time.time()

        #Construccion del hamiltoniano
        H = construccion_hamiltoniano(N, 1.0, 1.0)

        # Diagonalizamos
        autovalores, autovectores = np.linalg.eigh(H)

        t_fin = time.time()
